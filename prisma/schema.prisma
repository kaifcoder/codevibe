generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id               String    @id
  title            String    @default("Untitled Session")
  threadId         String?   // LangGraph thread ID — messages stored by PG checkpointer
  fileTree         Json      @default("[]") // File tree with content — survives sandbox expiry
  shareToken       String    @unique @default(cuid())
  isPublic         Boolean   @default(false)
  sandboxId        String?
  sandboxUrl       String?
  sandboxCreatedAt DateTime?
  userId           String?   // Clerk user ID
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shareToken])
  @@index([userId])
  @@index([threadId])
}
