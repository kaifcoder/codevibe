generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id               String    @id
  title            String    @default("Untitled Session")
  threadId         String?   // LangGraph thread ID — messages stored by PG checkpointer
  fileTree         Json      @default("[]") // File tree with content — survives sandbox expiry
  shareToken       String    @unique @default(cuid())
  isPublic         Boolean   @default(false)
  sandboxId        String?
  sandboxUrl       String?
  sandboxCreatedAt DateTime?
  templateType     String    @default("nextjs") // "nextjs" | "n8n" — picks sandbox image + agent prompt
  templateDecided  Boolean   @default(false)    // set true after HITL classification on first prompt
  // GitHub link — set after the user pushes/imports. Subsequent commits push
  // back here instead of prompting for a target each time.
  githubRepo       String?   // "owner/name"
  githubBranch     String?   // default branch we commit to (usually "main")
  userId           String?   // Clerk user ID
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shareToken])
  @@index([userId])
  @@index([threadId])
}

model McpServerConfig {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  url                  String
  authType             String   // 'bearer' | 'none' | 'oauth'
  encryptedBearerToken String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  oauthCredential      McpOAuthCredential?

  @@index([userId])
}

model McpOAuthCredential {
  serverId            String  @id
  encryptedClientInfo String?
  encryptedTokens     String?
  codeVerifier        String?
  updatedAt           DateTime @updatedAt
  server              McpServerConfig @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// One row per LLM call. Written by the Next.js ingest endpoint
// (/api/ingest/usage) on a fire-and-forget POST from the agent's
// usage-tracking middleware. Lets us answer "who burned the most $ today",
// build per-user quotas, and detect cost anomalies without parsing logs.
model Usage {
  id                String   @id @default(cuid())
  userId            String
  threadId          String
  sessionId         String?
  modelId           String?
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cacheReadTokens   Int      @default(0)
  cacheCreateTokens Int      @default(0)
  costUsd           Float    @default(0)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([threadId])
  @@index([createdAt])
}

// One row per abuse signal: rate-limit trip, sandbox-spam, auth failure
// burst, cost spike. The unique pair (userId, kind, windowStart) acts as a
// dedupe key so we don't write/alert on every offending request — only the
// first one per cooldown window does.
model AbuseEvent {
  id          String   @id @default(cuid())
  userId      String   // "anon" if unauthenticated; IP-derived hash if available
  kind        String   // "rate_limit" | "auth_failed" | "sandbox_spam" | "cost_spike"
  message     String
  metadata    Json     @default("{}")
  windowStart DateTime // bucketed timestamp — see ALERT_COOLDOWN_SEC in alerts.ts
  createdAt   DateTime @default(now())

  @@unique([userId, kind, windowStart])
  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

