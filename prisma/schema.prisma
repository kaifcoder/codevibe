generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id               String    @id
  title            String    @default("Untitled Session")
  threadId         String?   // LangGraph thread ID — messages stored by PG checkpointer
  fileTree         Json      @default("[]") // File tree with content — survives sandbox expiry
  shareToken       String    @unique @default(cuid())
  isPublic         Boolean   @default(false)
  sandboxId        String?
  sandboxUrl       String?
  sandboxCreatedAt DateTime?
  templateType     String    @default("nextjs") // "nextjs" | "n8n" — picks sandbox image + agent prompt
  templateDecided  Boolean   @default(false)    // set true after HITL classification on first prompt
  // GitHub link — set after the user pushes/imports. Subsequent commits push
  // back here instead of prompting for a target each time.
  githubRepo       String?   // "owner/name"
  githubBranch     String?   // default branch we commit to (usually "main")
  userId           String?   // Clerk user ID
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shareToken])
  @@index([userId])
  @@index([threadId])
}
