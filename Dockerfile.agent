FROM langchain/langgraphjs-api:22

WORKDIR /deps/codevibe

# Copy dependency manifests + Prisma schema first, for layer caching.
# package.json's postinstall runs `prisma generate`, which needs
# prisma/schema.prisma + prisma.config.ts to exist before `npm ci` runs.
COPY package.json package-lock.json prisma.config.ts ./
COPY prisma ./prisma

RUN npm ci

# Copy the rest of the source code (cache-busting only rebuilds from here)
COPY . .
